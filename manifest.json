{
  "manifest_version": 3,
  "name": "Idleon-Api-Downloader",
  "version": "0.5.0",
  "description": "Download and copy Idleon save data for tools and spreadsheets.",
  "action": {
    "default_popup": "index.html",
    "default_title": "Idleon API Downloader"
  },
  "options_page": "options.html",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.legendsofidleon.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.legendsofidleon.com/*"
      ],
      "js": [
        "js/inject.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "js/injected.js"
      ],
      "matches": [
        "*://*.legendsofidleon.com/*"
      ]
    }
  ]
}
