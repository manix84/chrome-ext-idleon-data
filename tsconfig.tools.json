{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "strict": false,
    "target": "ES2022",
    "types": ["node"]
  },
  "include": [
    "eslint.config.mjs",
    "scripts/**/*.mjs",
    "test/**/*.mjs",
    "tools/**/*.mjs"
  ]
}
