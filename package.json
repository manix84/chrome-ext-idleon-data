{
  "name": "idleon-api-downloader",
  "version": "0.3.0",
  "private": true,
  "description": "Chrome extension for downloading and copying Idleon save data.",
  "type": "module",
  "scripts": {
    "build": "node scripts/build-extension.mjs",
    "build:release": "node scripts/build-release.mjs",
    "lint": "eslint .",
    "test": "node --test",
    "typecheck": "tsc -p tsconfig.extension.json --noEmit && tsc -p tsconfig.tools.json --noEmit",
    "validate": "npm run build && node tools/validate-extension.mjs dist/extension"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^24.0.10",
    "eslint": "^9.30.1",
    "globals": "^16.2.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.62.1"
  }
}
